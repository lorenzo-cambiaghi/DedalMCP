{
  "type": "script_template",
  "version": 1,
  "name": "rock",
  "category": "prop",
  "description": "Irregular rock (displaced icosphere). Size: x=approximate diameter",
  "default_colors": {"body": "#777777"},
  "size_defaults": {"x": 1},
  "script": [
    "import bmesh",
    "import random",
    "s = {x}",
    "mesh_name = {name|repr}",
    "",
    "bpy.ops.mesh.primitive_ico_sphere_add(radius=s/2, subdivisions=2)",
    "obj = bpy.context.active_object",
    "obj.name = mesh_name",
    "obj.location = (0, 0, s * 0.3)",
    "obj.scale = (1, 0.8, 0.6)",
    "bpy.ops.object.transform_apply(scale=True)",
    "",
    "bm = bmesh.new()",
    "bm.from_mesh(obj.data)",
    "random.seed(hash(mesh_name))",
    "amp_xy = s * 0.08",
    "amp_z = s * 0.05",
    "for v in bm.verts:",
    "    v.co.x += random.uniform(-amp_xy, amp_xy)",
    "    v.co.y += random.uniform(-amp_xy, amp_xy)",
    "    v.co.z += random.uniform(-amp_z, amp_z)",
    "bm.to_mesh(obj.data)",
    "bm.free()",
    "_set_vertex_color_all(obj, {color.body|repr})"
  ]
}
