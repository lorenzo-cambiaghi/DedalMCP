{
  "type": "composite",
  "version": 1,
  "name": "tree_round",
  "category": "prop",
  "description": "Round tree (sphere on cylinder). Size: y=total height. Colors: trunk, crown",
  "default_colors": {"trunk": "#6B4226", "crown": "#2D8B2D"},
  "size_defaults": {"y": 4},
  "parts": [
    {
      "shape": "cylinder",
      "params": {"radius": "y*0.04", "depth": "y*0.4", "vertices": 8},
      "location": [0, 0, "y*0.4/2"],
      "color": "trunk"
    },
    {
      "shape": "sphere",
      "params": {"radius": "y*0.25", "segments": 12, "ring_count": 8},
      "location": [0, 0, "y*0.4 + y*0.25 * 0.7"],
      "color": "crown"
    }
  ],
  "join": true
}
