{
  "type": "script_template",
  "version": 1,
  "name": "chair",
  "category": "prop",
  "description": "Simple chair with back. Size: x=width, y=seat height, z=depth. Colors: seat, legs",
  "default_colors": {"seat": "#A0784C", "legs": "#6B4226"},
  "size_defaults": {"x": 0.45, "y": 0.45, "z": 0.45},
  "script": [
    "w = {x}",
    "seat_h = {y}",
    "d = {z}",
    "back_h = seat_h * 0.8",
    "leg_t = 0.025",
    "mesh_name = {name|repr}",
    "seat_color = {color.seat|repr}",
    "leg_color = {color.legs|repr}",
    "",
    "bpy.ops.mesh.primitive_cube_add(size=1)",
    "seat = bpy.context.active_object",
    "seat.name = mesh_name + '_seat'",
    "seat.scale = (w/2, d/2, 0.02)",
    "seat.location = (0, 0, seat_h)",
    "bpy.ops.object.transform_apply(scale=True)",
    "_set_vertex_color_all(seat, seat_color)",
    "",
    "bpy.ops.mesh.primitive_cube_add(size=1)",
    "back = bpy.context.active_object",
    "back.name = mesh_name + '_back'",
    "back.scale = (w/2, 0.02, back_h/2)",
    "back.location = (0, -d/2 + 0.02, seat_h + back_h/2)",
    "bpy.ops.object.transform_apply(scale=True)",
    "_set_vertex_color_all(back, seat_color)",
    "",
    "offsets = [",
    "    (w/2 - leg_t, d/2 - leg_t),",
    "    (-w/2 + leg_t, d/2 - leg_t),",
    "    (w/2 - leg_t, -d/2 + leg_t),",
    "    (-w/2 + leg_t, -d/2 + leg_t),",
    "]",
    "legs = []",
    "for i, (lx, ly) in enumerate(offsets):",
    "    bpy.ops.mesh.primitive_cube_add(size=1)",
    "    leg = bpy.context.active_object",
    "    leg.name = mesh_name + '_leg_' + str(i)",
    "    leg.scale = (leg_t, leg_t, seat_h / 2)",
    "    leg.location = (lx, ly, seat_h / 2)",
    "    bpy.ops.object.transform_apply(scale=True)",
    "    _set_vertex_color_all(leg, leg_color)",
    "    legs.append(leg)",
    "",
    "for o in [seat, back] + legs:",
    "    o.select_set(True)",
    "bpy.context.view_layer.objects.active = seat",
    "bpy.ops.object.join()",
    "obj = bpy.context.active_object",
    "obj.name = mesh_name"
  ]
}
