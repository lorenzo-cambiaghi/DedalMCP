{
  "type": "script_template",
  "version": 1,
  "name": "house",
  "category": "architecture",
  "description": "Simple house: box walls + peaked roof + door. Size: x=width, y=height, z=depth. Colors: walls, roof, door",
  "default_colors": {"walls": "#C0C0C0", "roof": "#CC4444", "door": "#664422"},
  "size_defaults": {"x": 4, "y": 3, "z": 5},
  "script": [
    "import bmesh",
    "w = {x}",
    "h = {y}",
    "d = {z}",
    "roof_h = h * 0.5",
    "mesh_name = {name|repr}",
    "",
    "bpy.ops.mesh.primitive_cube_add(size=1)",
    "walls = bpy.context.active_object",
    "walls.name = mesh_name + '_walls'",
    "walls.scale = (w/2, d/2, h/2)",
    "walls.location = (0, 0, h/2)",
    "bpy.ops.object.transform_apply(scale=True)",
    "_set_vertex_color_all(walls, {color.walls|repr})",
    "",
    "bpy.ops.mesh.primitive_cube_add(size=1)",
    "roof = bpy.context.active_object",
    "roof.name = mesh_name + '_roof'",
    "roof.scale = (w/2 + 0.2, d/2 + 0.2, roof_h/2)",
    "roof.location = (0, 0, h + roof_h/2)",
    "bpy.ops.object.transform_apply(scale=True)",
    "bm = bmesh.new()",
    "bm.from_mesh(roof.data)",
    "for v in bm.verts:",
    "    if v.co.z > 0.01:",
    "        v.co.x *= 0.01",
    "bm.to_mesh(roof.data)",
    "bm.free()",
    "_set_vertex_color_all(roof, {color.roof|repr})",
    "",
    "bpy.ops.mesh.primitive_cube_add(size=1)",
    "door = bpy.context.active_object",
    "door.name = mesh_name + '_door'",
    "door.scale = (0.4, 0.05, h * 0.55 / 2)",
    "door.location = (0, -(d/2 + 0.01), h * 0.55 / 2)",
    "bpy.ops.object.transform_apply(scale=True)",
    "_set_vertex_color_all(door, {color.door|repr})",
    "",
    "for o in [walls, roof, door]:",
    "    o.select_set(True)",
    "bpy.context.view_layer.objects.active = walls",
    "bpy.ops.object.join()",
    "obj = bpy.context.active_object",
    "obj.name = mesh_name"
  ]
}
