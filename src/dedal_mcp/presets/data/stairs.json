{
  "type": "script_template",
  "version": 1,
  "name": "stairs",
  "category": "architecture",
  "description": "Staircase. Size: x=width, y=total height, z=total depth, steps=step count (default 8)",
  "default_colors": {"body": "#B0B0B0"},
  "size_defaults": {"x": 2, "y": 3, "z": 4, "steps": 8},
  "script": [
    "w = {x}",
    "h = {y}",
    "d = {z}",
    "steps = int({steps})",
    "step_h = h / steps",
    "step_d = d / steps",
    "mesh_name = {name|repr}",
    "step_color = {color.body|repr}",
    "",
    "for i in range(steps):",
    "    bpy.ops.mesh.primitive_cube_add(size=1)",
    "    s = bpy.context.active_object",
    "    s.name = mesh_name + '_step_' + str(i)",
    "    s.scale = (w/2, step_d/2, step_h/2)",
    "    s.location = (0, -d/2 + step_d/2 + i * step_d, step_h/2 + i * step_h)",
    "    bpy.ops.object.transform_apply(scale=True)",
    "    _set_vertex_color_all(s, step_color)",
    "",
    "bpy.ops.object.select_all(action='SELECT')",
    "bpy.context.view_layer.objects.active = bpy.data.objects[mesh_name + '_step_0']",
    "bpy.ops.object.join()",
    "obj = bpy.context.active_object",
    "obj.name = mesh_name"
  ]
}
