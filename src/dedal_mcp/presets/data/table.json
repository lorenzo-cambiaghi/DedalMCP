{
  "type": "script_template",
  "version": 1,
  "name": "table",
  "category": "prop",
  "description": "Simple table. Size: x=width, y=height, z=depth. Colors: top, legs",
  "default_colors": {"top": "#A0784C", "legs": "#6B4226"},
  "size_defaults": {"x": 1.2, "y": 0.75, "z": 0.8},
  "script": [
    "w = {x}",
    "h = {y}",
    "d = {z}",
    "top_t = 0.05",
    "leg_r = 0.03",
    "mesh_name = {name|repr}",
    "top_color = {color.top|repr}",
    "leg_color = {color.legs|repr}",
    "",
    "bpy.ops.mesh.primitive_cube_add(size=1)",
    "top = bpy.context.active_object",
    "top.name = mesh_name + '_top'",
    "top.scale = (w/2, d/2, top_t/2)",
    "top.location = (0, 0, h)",
    "bpy.ops.object.transform_apply(scale=True)",
    "_set_vertex_color_all(top, top_color)",
    "",
    "leg_h = h - top_t",
    "offsets = [",
    "    (w/2 - leg_r*2, d/2 - leg_r*2),",
    "    (-w/2 + leg_r*2, d/2 - leg_r*2),",
    "    (w/2 - leg_r*2, -d/2 + leg_r*2),",
    "    (-w/2 + leg_r*2, -d/2 + leg_r*2),",
    "]",
    "legs = []",
    "for i, (lx, ly) in enumerate(offsets):",
    "    bpy.ops.mesh.primitive_cube_add(size=1)",
    "    leg = bpy.context.active_object",
    "    leg.name = mesh_name + '_leg_' + str(i)",
    "    leg.scale = (leg_r, leg_r, leg_h / 2)",
    "    leg.location = (lx, ly, leg_h / 2)",
    "    bpy.ops.object.transform_apply(scale=True)",
    "    _set_vertex_color_all(leg, leg_color)",
    "    legs.append(leg)",
    "",
    "for o in [top] + legs:",
    "    o.select_set(True)",
    "bpy.context.view_layer.objects.active = top",
    "bpy.ops.object.join()",
    "obj = bpy.context.active_object",
    "obj.name = mesh_name"
  ]
}
