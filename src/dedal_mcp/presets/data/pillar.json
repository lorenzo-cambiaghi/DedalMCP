{
  "type": "composite",
  "version": 1,
  "name": "pillar",
  "category": "architecture",
  "description": "Column with base and capital. Size: x=diameter, y=height. Colors: base (used for capital too), shaft",
  "default_colors": {"base": "#999999", "shaft": "#C0C0C0"},
  "size_defaults": {"x": 0.4, "y": 3},
  "parts": [
    {
      "shape": "cylinder",
      "params": {"radius": "x/2 * 1.3", "depth": 0.15, "vertices": 16},
      "location": [0, 0, 0.075],
      "color": "base"
    },
    {
      "shape": "cylinder",
      "params": {"radius": "x/2", "depth": "y - 0.3", "vertices": 16},
      "location": [0, 0, "y/2"],
      "color": "shaft"
    },
    {
      "shape": "cylinder",
      "params": {"radius": "x/2 * 1.3", "depth": 0.15, "vertices": 16},
      "location": [0, 0, "y - 0.075"],
      "color": "base"
    }
  ],
  "join": true
}
